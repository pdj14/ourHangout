{
  "name": "kidchat-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel --port 19000",
    "android": "expo run:android",
    "android:tunnel": "expo start --android --tunnel --port 19000",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "config:check": "expo config --type public",
    "version:print": "node scripts/build-version.js",
    "build:apk": "npx eas-cli build -p android --profile preview"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "expo": "~55.0.4",
    "expo-background-task": "~55.0.10",
    "expo-constants": "~55.0.7",
    "expo-device": "~55.0.9",
    "expo-image-manipulator": "~55.0.9",
    "expo-image-picker": "~55.0.10",
    "expo-intent-launcher": "~55.0.9",
    "expo-linear-gradient": "~55.0.8",
    "expo-location": "~55.1.4",
    "expo-media-library": "~55.0.9",
    "expo-notifications": "~55.0.11",
    "expo-secure-store": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "expo-task-manager": "~55.0.10",
    "expo-video": "~55.0.10",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2"
